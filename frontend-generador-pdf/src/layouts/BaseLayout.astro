---
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Convertidor de Archivos</title>

    <!-- Bootstrap -->
    <link 
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" 
      rel="stylesheet"
    />

    <style>
      .bg-navy {
        background-color: #001f3f;
      }
    </style>
  </head>

  <body class="d-flex flex-column min-vh-100 bg-light">

    <header class="bg-navy text-white text-center py-4">
      <h1 class="m-0">Convertidor de Archivos</h1>
    </header>

    <main class="container my-5 flex-grow-1">
      <slot />
    </main>

    <footer class="bg-navy text-white text-center py-3 mt-auto">
      <p class="m-0">Proyecto con Astro</p>
    </footer>

  </body>
</html>